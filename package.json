{
  "name": "superset-devin-demo",
  "version": "0.1.0",
  "description": "GitHub Action that spawns a Devin session when an issue is labeled 'devin'. Devin opens a PR against this repo.",
  "private": true,
  "type": "module",
  "scripts": {
    "spawn": "tsx src/index.ts",
    "upload-knowledge": "tsx src/upload-knowledge.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
